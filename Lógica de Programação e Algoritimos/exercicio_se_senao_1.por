programa {
  funcao inicio() {
    inteiro num1, num2

    escreva("digite o primeiro numero:")
    leia(num1)

    escreva("digite o segundo numero:")
    leia(num2)

    se(num1>num2)
    escreva("num1>num2")
    
    senao se(num2>num1){
      escreva("num2>num1")
    }
    senao se(num1 == num2){
       escreva(" os números são iguais")
    }
   

    
  }
}
