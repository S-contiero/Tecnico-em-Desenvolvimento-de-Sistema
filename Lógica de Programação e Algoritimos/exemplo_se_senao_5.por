programa {
  funcao inicio() {
    inteiro idade
    cadeia possui_cnh

    escreva("Digite sua iadade:")
    leia (idade)

    escreva("Você tem cnh?")
    leia(possui_cnh)

    se(idade>18 e possui_cnh == "sim"){
      esreva("pode drigir!")
    }
    senao{
      escreva("Você não pode dirigir!")
    }
  }
}
